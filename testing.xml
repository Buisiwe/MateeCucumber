<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Cucumber Test Suite" thread-count="1" parallel="false" verbose="2">
    <listeners>
        <listener class-name="utils.Listener"/>
    </listeners>
    <test verbose="2" preserve-order="true" name="Cucumber Features" thread-count="1" parallel="false">
        <classes>
            <class name="runner.TestRunner">
                <methods>
                    <include name=".*"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>

